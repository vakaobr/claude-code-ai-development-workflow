# Copy to .env and fill in only the keys you have. All are OPTIONAL — the
# corresponding checks degrade gracefully (return empty data) without them.
# Then uncomment `env_file: - .env` in docker-compose.yml.
#
# Do NOT commit a populated .env. .gitignore in this skill dir excludes it.

# Shodan — host/port/banner intelligence (passive: queries Shodan's DB)
SHODAN_API_KEY=''

# SecurityTrails — passive subdomain enumeration
SECURITY_TRAILS_API_KEY=''

# Google Cloud — geolocation / some enrichment
GOOGLE_CLOUD_API_KEY=''

# Tranco — global ranking
TRANCO_USERNAME=''
TRANCO_API_KEY=''

# urlscan.io — historical scan lookups
URL_SCAN_API_KEY=''

# WhoAPI — richer WHOIS
WHO_API_KEY=''
